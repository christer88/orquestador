{
  "name": "DeepSeek (OR) + Xiaomi MiMo",
  "description": "Combina la inteligencia de DeepSeek Pro y Flash (vía OpenRouter) con los modelos de Xiaomi MiMo (API Pay-as-you-go).",
  "providers": [
    "openrouter",
    "xiaomi"
  ],
  "accounts": {
    "opencode-go": [
      {
        "id": "opencode-go-1",
        "label": "Cuenta Principal"
      }
    ],
    "commandcode": [
      {
        "id": "commandcode-1",
        "label": "Cuenta Principal"
      }
    ],
    "xiaomi": [
      {
        "id": "xiaomi-1",
        "label": "Cuenta Principal"
      }
    ],
    "openrouter": [
      {
        "id": "openrouter-1",
        "label": "OpenRouter"
      }
    ],
    "cavoti": [
      {
        "id": "cavoti-1",
        "label": "Cavoti Americas"
      }
    ]
  },
  "agents": {
    "sisyphus": {
      "model": "deepseek-v4-pro",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "hephaestus": {
      "model": "mimo-v2.5-pro",
      "source": "a2f23c1a-e403-4ca4-8351-d5f877eaf264",
      "fallbacks": []
    },
    "oracle": {
      "model": "mimo-v2-omni",
      "source": "a2f23c1a-e403-4ca4-8351-d5f877eaf264",
      "fallbacks": []
    },
    "librarian": {
      "model": "deepseek-v4-flash",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "explore": {
      "model": "mimo-v2-flash",
      "source": "a2f23c1a-e403-4ca4-8351-d5f877eaf264",
      "fallbacks": []
    },
    "multimodal-looker": {
      "model": "mimo-v2-omni",
      "source": "a2f23c1a-e403-4ca4-8351-d5f877eaf264",
      "fallbacks": []
    },
    "prometheus": {
      "model": "deepseek-v4-pro",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "metis": {
      "model": "deepseek-v4-pro",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "momus": {
      "model": "deepseek-v4-flash",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "atlas": {
      "model": "mimo-v2.5-pro",
      "source": "a2f23c1a-e403-4ca4-8351-d5f877eaf264",
      "fallbacks": []
    },
    "code-reviewer": {
      "model": "deepseek-v4-pro",
      "source": "openrouter-1",
      "fallbacks": []
    },
    "sisyphus-junior": {
      "model": "deepseek-v4-flash",
      "source": "openrouter-1",
      "fallbacks": []
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000
  }
}