{
  "name": "Budget Single",
  "description": "Configuración económica con 1× OpenCode Go — todos los agentes usan modelos de bajo costo",
  "providers": ["opencode-go"],
  "accounts": {
    "opencode-go": [{ "id": "opencode-go-1", "label": "Cuenta Principal" }]
  },
  "agents": {
    "sisyphus": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "hephaestus": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "oracle": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "librarian": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "explore": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "multimodal-looker": { "model": "mimo-v2-omni", "source": "opencode-go-1", "fallbacks": [] },
    "prometheus": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "metis": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "momus": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "atlas": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "code-reviewer": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] },
    "sisyphus-junior": { "model": "deepseek-v4-flash", "source": "opencode-go-1", "fallbacks": [] }
  },
  "runtime_fallback": {
    "enabled": false,
    "retry_on_errors": [429, 503],
    "max_fallback_attempts": 1,
    "cooldown_seconds": 120,
    "timeout_seconds": 30,
    "notify_on_fallback": false
  },
  "background_task": {
    "defaultConcurrency": 3,
    "staleTimeoutMs": 180000
  }
}
