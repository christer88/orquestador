{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek-v4-flash",
  "providers": {
    "opencode-go-1": {
      "apiKey": "{env:OPENCODE_GO_1_AUTH}",
      "options": {
        "setCacheKey": true,
        "headers": {
          "x-session-id": "{env:PROJECT_CACHE_ID}"
        }
      }
    },
    "commandcode-1": {
      "apiKey": "{env:COMMANDCODE_1_API_KEY}",
      "options": {
        "setCacheKey": true,
        "headers": {
          "x-session-id": "{env:PROJECT_CACHE_ID}"
        }
      }
    }
  },
  "theme": "opencode",
  "autoupdate": true
}